<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardBackgroundColor="@color/colorSurface"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/colorOutlineVariant"
    app:strokeWidth="1dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="84dp"
        android:paddingStart="18dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <ImageView
            android:id="@+id/item_server_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_server" />

        <ImageView
            android:id="@+id/item_server_status"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_alignBottom="@+id/item_server_icon"
            android:layout_marginStart="-12dp"
            android:layout_toEndOf="@+id/item_server_icon"
            android:src="@drawable/ic_round_check"
            android:visibility="gone"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/item_server_des_area"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="18dp"
            android:layout_toStartOf="@+id/item_server_action"
            android:layout_toEndOf="@+id/item_server_icon"
            android:gravity="start"
            android:orientation="vertical"
            android:paddingEnd="10dp">

            <TextView
                android:id="@+id/item_server_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:singleLine="true"
                android:textColor="@color/color_text_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="新建服务器" />

            <TextView
                android:id="@+id/item_server_address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="marquee"
                android:singleLine="true"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="13sp"
                tools:text="ftp://192.168.1.101:5656" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/item_server_action"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/word_connect"
            android:textAllCaps="false"
            android:textColor="@color/colorPrimary"
            app:cornerRadius="20dp"
            app:strokeColor="@color/colorOutline" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/item_server_progress"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:visibility="gone"
            app:indicatorSize="24dp"
            app:trackThickness="3dp"
            tools:visibility="visible" />
    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>
